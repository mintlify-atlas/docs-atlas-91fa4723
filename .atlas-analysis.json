  "keyFeatures": [
    "Internal stock request management with draft/open/done/cancel workflow",
    "Stock Request Orders for grouping and kanban-style management",
    "Automatic procurement rule evaluation and transfer generation",
    "Purchase Order integration for automatic PO creation",
    "Manufacturing Order (MRP) integration for production requests",
    "BOM integration for component explosion",
    "Tier validation for approval workflows",
    "Stock return request handling"
